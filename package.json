{
  "name": "@sureshsk/react-hooks",
  "version": "0.2.0",
  "description": "A small, dependency-free, TypeScript-first collection of headless React hooks.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "react19",
    "hooks",
    "react-hooks",
    "usedebounce",
    "debounce",
    "usefocustrap",
    "focus-trap",
    "accessibility",
    "a11y",
    "typescript",
    "headless"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "jsdom": "^24.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2suresh/react-hooks.git"
  },
  "homepage": "https://github.com/2suresh/react-hooks#readme",
  "bugs": {
    "url": "https://github.com/2suresh/react-hooks/issues"
  },
  "author": "Suresh Kumar"
}